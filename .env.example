# ============================================================
# DeepAgent Chat — 环境变量模板
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================================

# ── 数据库加密密钥（可选，默认从 SECRET_KEY 派生）──
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# ── Flask ──
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=development

# ── 数据库 ──
# SQLite（默认）
DATABASE_URL=sqlite:///app.db
# MySQL（取消注释下一行，注释掉上一行；需先创建数据库）
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/dbname?charset=utf8mb4

# ── 应用时区（可选，默认 Asia/Shanghai）──
# 支持 IANA 时区名称，如 America/New_York、Europe/London
# APP_TIMEZONE=Asia/Shanghai

# ── 管理员初始密码（可选，不设置则自动生成随机密码并打印到日志）──
ADMIN_PASSWORD=

# ── SMTP 邮件（邮箱验证/密码重置）──
MAIL_SERVER=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=your-email@example.com

# ── 智谱 AI（GLM 大模型 + 图片生成）──
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_VISION_MODEL=glm-4v-flash
ZHIPU_IMAGE_MODEL=cogview-3-flash

# ── 网络搜索（Serper API）──
# Tavily search api
TAVILY_API_KEY=your-tavily-api-key
# serper search api
SERPER_API_KEY=your-serper-api-key

# ── 向量嵌入（DashScope/阿里云通义千问）──
QUERY_EMBEDDING_MODEL=text-embedding-v4
QUERY_EMBEDDING_API_KEY=your-dashscope-api-key
QUERY_EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# 用于查询Aliyun余额
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# ── URL 获取器（url_fetcher skill，可选）──
# 百度百家号等反爬严格的站点需要 Cookie
# 从浏览器开发者工具 → Network → 任意请求 → Request Headers → Cookie 复制
# BAIDU_COOKIE=your-baidu-cookie-here

# ── Chroma 远程连接（可选，默认本地持久化）──
# CHROMA_HOST=192.168.1.100
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_HEADERS={"Authorization": "Bearer your-token"}


#  ── TTS 模式（文本转语音）──
# auto:    优先使用离线 TTS（模型已下载时），否则使用 Edge TTS（在线）
# online:  强制使用 Edge TTS（在线，需要网络）
# offline: 强制使用 Sherpa-ONNX（离线，无需网络）
TTS_MODE=auto
# 离线 TTS 模型名称（vits-zh 或 vits-zh-llm）
OFFLINE_TTS_MODEL=vits-zh
# 离线 TTS 说话人 ID（0=女声，1=男声）
OFFLINE_TTS_SPEAKER=0
# 离线 TTS 语速（1.0=正常）
OFFLINE_TTS_SPEED=1.0

#  ── 豆包（火山引擎）流式语音识别 ──
# 用于 meeting_recorder 插件的实时字幕和录音转写
# 从火山引擎控制台获取：https://console.volcengine.com/speech/service/
# DOUBAO_ASR_APPID=your-app-id
# DOUBAO_ASR_TOKEN=your-access-token
# DOUBAO_ASR_CLUSTER=volcengine_streaming_common


